# Claude AI
ANTHROPIC_API_KEY=sk-ant-api03-...

# Vercel Postgres (auto-filled when you add Postgres integration in Vercel dashboard)
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Dashboard Auth
DASHBOARD_PASSWORD=your_secure_password_here
SESSION_SECRET=run_openssl_rand_hex_32_and_paste_here

# Cron Security (generate same way as SESSION_SECRET, or Vercel auto-provides it)
CRON_SECRET=run_openssl_rand_hex_32_and_paste_here

# Email Notifications (Resend.com)
RESEND_API_KEY=re_...
NOTIFICATION_EMAIL=your@email.com

# Metricool API (optional — omit both to use copy mode)
METRICOOL_API_KEY=
METRICOOL_BLOG_ID=

# Content Config
PROMPTS_BASE_PATH=./prompts
